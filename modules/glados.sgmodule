[Script]
GLaDOS 抓包 = type=http-request, pattern=^https://glados\.network/console/account$, requires-body=0, script-path=https://raw.githubusercontent.com/curtinp118/Scripthub/main/scripts/glados/glados.js, timeout=10
GLaDOS 抓包2 = type=http-request, pattern=^https://railgun\.info/console/account$, requires-body=0, script-path=https://raw.githubusercontent.com/curtinp118/Scripthub/main/scripts/glados/glados.js, timeout=10
GLaDOS 抓包3 = type=http-request, pattern=^https://glados\.vip/console/account$, requires-body=0, script-path=https://raw.githubusercontent.com/curtinp118/Scripthub/main/scripts/glados/glados.js, timeout=10
GLaDOS 抓包4 = type=http-request, pattern=^https://glados\.one/console/account$, requires-body=0, script-path=https://raw.githubusercontent.com/curtinp118/Scripthub/main/scripts/glados/glados.js, timeout=10
GLaDOS 抓包5 = type=http-request, pattern=^https://glados\.space/console/account$, requires-body=0, script-path=https://raw.githubusercontent.com/curtinp118/Scripthub/main/scripts/glados/glados.js, timeout=10
GLaDOS 签到 = type=cron, cronexp="10 7 * * *", script-path=https://raw.githubusercontent.com/curtinp118/Scripthub/main/scripts/glados/glados.js, timeout=120

[MITM]
hostname = %APPEND% glados.network, railgun.info, glados.vip, glados.one, glados.space
